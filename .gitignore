# Repo-wide ignores. backend/ and client/ each carry their own .gitignore for
# toolchain-specific artefacts; this file holds only what's genuinely cross-cutting.

# Editors (metadata can sit at whichever level the IDE is opened)
.vscode/
.idea
*.iws
*.iml
*.ipr

# Env / secrets
.env
.env.local
*.env
!.env.example
