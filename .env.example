# Placeholders only — copy to .env (gitignored) and fill with real local values.
# Postgres connection (see docker-compose.yml for local defaults)
DATABASE_URL=jdbc:postgresql://localhost:5432/timesheet
DATABASE_USER=timesheet
DATABASE_PASSWORD=<your-local-db-password>
# Optional: host port for the containerised Postgres (defaults to 5432)
DATABASE_PORT=5432

# JWT (unused until Story 2 — declared now per env-surface convention)
JWT_SECRET=<generate-a-256-bit-secret>
JWT_TTL_DAYS=7
