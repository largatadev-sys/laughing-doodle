# Placeholders only — copy to .env (gitignored) and fill with real local values.
# Postgres connection. DATABASE_URL below is for the NATIVE daily loop (bootRun on the host,
# reaching the containerised Postgres at localhost). The full-stack gate's `app` service does
# NOT use this line — it overrides DATABASE_URL to jdbc:postgresql://postgres:5432/... (the
# compose service name) since it runs inside the compose network. See docker-compose.yml.
DATABASE_URL=jdbc:postgresql://localhost:5432/timesheet
DATABASE_USER=timesheet
DATABASE_PASSWORD=<your-local-db-password>
# Optional: host port for the containerised Postgres (defaults to 5432)
DATABASE_PORT=5432
# Optional: host port the full-stack gate publishes the app on (defaults to 8080)
APP_PORT=8080

# JWT. In the full-stack gate the placeholder is fine; in PROD set a real 256-bit secret in
# Railway's env UI (never the repo default).
JWT_SECRET=<generate-a-256-bit-secret>
JWT_TTL_DAYS=7

# CORS — origin patterns (comma-separated) allowed to call the API from a browser. Covers the
# Expo web dev server (a different origin from the API during daily dev). In prod the web is
# served by the app on the SAME origin (ADR-008), so CORS never triggers there.
CORS_ALLOWED_ORIGINS=http://localhost:*
